{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/orders/layout,_N_T_/orders/dashboard/layout,_N_T_/orders/dashboard/page,_N_T_/orders/dashboard"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/orders/dashboard/__PAGE__",
    "/orders/dashboard",
    "/orders",
    "/_index",
    "/_head"
  ]
}